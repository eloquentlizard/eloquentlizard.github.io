\define find_original()
<$list filter="[field:alias/\|$(the_alias)$\|/(i)sort[title]limit[1]]"><$link>{{$(the_alias)$||unwikified}}</$link></$list>
\end

<$set name="the_alias" value={{!!title}}><<find_original>></$set>