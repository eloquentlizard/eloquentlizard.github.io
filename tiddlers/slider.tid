\define slider(label)
<$button popup="$:/state/$label$" class="tc-btn-invisible tw-slider large"><$reveal type="match" text="" default="" state="$:/state/$label$">{{$:/core/images/right-arrow}}</$reveal><$reveal type="nomatch" text="" default="" state="$:/state/$label$">{{$:/core/images/down-arrow}}</$reveal> {{$label$||unwikified}}</$button>
<$reveal type="nomatch" text="" default="" state="$:/state/$label$" animate="yes">
<div>

<blockquote>

<$transclude/>

</blockquote>

</div>
</$reveal>
\end

<$macrocall $name="slider" label={{!!title}}/>