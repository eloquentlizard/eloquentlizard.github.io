{
    "description": "Basic client-server edition",
    "plugins": [
        "tiddlywiki/tiddlyweb",
        "tiddlywiki/filesystem",
        "tiddlywiki/highlight",
        "tiddlywiki/codemirror",
        "tiddlywiki/codemirror-autocomplete",
        "tiddlywiki/codemirror-closebrackets",
        "tiddlywiki/codemirror-closetag",
        "tiddlywiki/codemirror-mode-css",
        "tiddlywiki/codemirror-mode-htmlembedded",
        "tiddlywiki/codemirror-mode-htmlmixed",
        "tiddlywiki/codemirror-mode-javascript",
        "tiddlywiki/codemirror-mode-markdown",
        "tiddlywiki/codemirror-mode-xml",
        "tiddlywiki/codemirror-mode-x-tiddlywiki",
        "tiddlywiki/codemirror-search-replace",
        "tiddlywiki/d3",
        "tiddlywiki/browser-sniff",
        "tiddlywiki/blog",
        "tiddlywiki/external-attachments",
        "tiddlywiki/github-fork-ribbon",
        "tiddlywiki/internals",
        "tiddlywiki/katex",
        "tiddlywiki/sax",
        "tiddlywiki/jszip",
        "tiddlywiki/menubar",
        "tiddlywiki/qrcode",
        "tiddlywiki/stacked-view",
        "tiddlywiki/text-slicer",
        "tiddlywiki/xlsx-utils",
        "tiddlywiki/xmldom",
        "tiddlywiki/dynaview",
        "tiddlywiki/nodewebkitsaver"
    ],
    "themes": [
        "tiddlywiki/vanilla",
        "tiddlywiki/snowwhite",
        "tiddlywiki/centralised",
        "tiddlywiki/heavier",
        "tiddlywiki/readonly",
        "tiddlywiki/seamless",
        "tiddlywiki/starlight",
        "tiddlywiki/tight",
        "tiddlywiki/tight-heavier"
    ],
    "languages": [
        "en-US"
    ],
    "build": {
        "index": [
            "--rendertiddler",
            "$:/plugins/tiddlywiki/tiddlyweb/save/offline",
            "index.html",
            "text/plain"
        ], 
        "favicon": [
            "--savetiddler",
            "$:/favicon.ico",
            "favicon.ico"
        ],
        "static": [
            "--rendertiddler",
            "$:/core/templates/static.template.html",
            "static.html",
            "text/plain",
            "--rendertiddler",
            "$:/core/templates/alltiddlers.template.html",
            "alltiddlers.html",
            "text/plain",
            "--rendertiddlers",
            "[!is[system]]",
            "$:/core/templates/static.tiddler.html",
            "static",
            "text/plain",
            "--rendertiddler",
            "$:/core/templates/static.template.css",
            "static/static.css",
            "text/plain"
        ]
    },
	"config": {
		"retain-original-tiddler-path": true
	}
}